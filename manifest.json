{
  "manifest_version": 3,
  "name": "LinuxDo Star - 收藏助手",
  "version": "1.1.0",
  "description": "为 linux.do 论坛添加帖子和评论收藏功能",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://linux.do/*"],
  "content_scripts": [
    {
      "matches": ["https://linux.do/t/*"],
      "js": ["storage.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon-48.svg"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "48": "icons/icon-48.svg",
    "128": "icons/icon-48.svg"
  }
}
